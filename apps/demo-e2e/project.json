{
  "name": "demo-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/demo-e2e/src",
  "implicitDependencies": ["demo"],
  "tags": ["scope:demo", "type:app"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint {projectRoot} --type-aware"
      }
    },
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "outputs": ["{workspaceRoot}/dist/.playwright/apps/demo-e2e"],
      "options": {
        "config": "{projectRoot}/playwright.config.ts"
      }
    },
    "e2e-toolkit": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "zsh -lc 'lsof -nP -iTCP:4200 -sTCP:LISTEN -t | xargs -r kill; echo e2e-preflight-port-cleared'",
          "pnpm exec playwright test apps/demo-e2e/src/forms --grep-invert @layout --config apps/demo-e2e/playwright.config.ts --project=chromium"
        ],
        "parallel": false
      }
    },
    "e2e-demo-app": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "zsh -lc 'lsof -nP -iTCP:4200 -sTCP:LISTEN -t | xargs -r kill; echo e2e-preflight-port-cleared'",
          "pnpm exec playwright test apps/demo-e2e/src/ui --config apps/demo-e2e/playwright.config.ts --project=chromium"
        ],
        "parallel": false
      }
    },
    "e2e-layout": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "zsh -lc 'lsof -nP -iTCP:4200 -sTCP:LISTEN -t | xargs -r kill; echo e2e-preflight-port-cleared'",
          "pnpm exec playwright test apps/demo-e2e/src/ui --config apps/demo-e2e/playwright.config.ts --project=chromium",
          "pnpm exec playwright test apps/demo-e2e/src/forms --grep @layout --config apps/demo-e2e/playwright.config.ts --project=chromium"
        ],
        "parallel": false
      }
    },
    "e2e-ci": {
      "executor": "@nx/playwright:playwright",
      "outputs": ["{workspaceRoot}/dist/.playwright/apps/demo-e2e"],
      "options": {
        "config": "{projectRoot}/playwright.config.ts"
      }
    },
    "a11y": {
      "executor": "@nx/playwright:playwright",
      "outputs": [
        "{workspaceRoot}/dist/.playwright/apps/demo-e2e-a11y",
        "{workspaceRoot}/dist/.a11y/demo-e2e"
      ],
      "options": {
        "config": "{projectRoot}/playwright.a11y.config.ts"
      }
    }
  }
}
