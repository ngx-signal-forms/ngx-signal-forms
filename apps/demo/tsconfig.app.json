{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": [],
    "paths": {
      "@ngx-signal-forms/toolkit": [
        "../../packages/toolkit/index.ts",
        "../../dist/packages/toolkit"
      ],
      "@ngx-signal-forms/toolkit/core": [
        "../../packages/toolkit/core/index.ts"
      ],
      "@ngx-signal-forms/toolkit/assistive": [
        "../../packages/toolkit/assistive/index.ts",
        "../../dist/packages/toolkit/assistive"
      ],
      "@ngx-signal-forms/toolkit/debugger": [
        "../../packages/toolkit/debugger/index.ts",
        "../../dist/packages/toolkit/debugger"
      ],
      "@ngx-signal-forms/toolkit/form-field": [
        "../../packages/toolkit/form-field/public_api.ts",
        "../../dist/packages/toolkit/form-field"
      ],
      "@ngx-signal-forms/toolkit/headless": [
        "../../packages/toolkit/headless/src/index.ts",
        "../../dist/packages/toolkit/headless"
      ],
      "@ngx-signal-forms/toolkit/vest": [
        "../../packages/toolkit/vest/src/index.ts",
        "../../dist/packages/toolkit/vest"
      ],
      "@ngx-signal-forms/demo-shared": [
        "../../packages/demo-shared/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "../../packages/demo-shared/src/**/*.ts",
    "../../packages/toolkit/index.ts",
    "../../packages/toolkit/core/**/*.ts",
    "../../packages/toolkit/assistive/**/*.ts",
    "../../packages/toolkit/debugger/**/*.ts",
    "../../packages/toolkit/form-field/**/*.ts",
    "../../packages/toolkit/headless/src/**/*.ts",
    "../../packages/toolkit/vest/src/**/*.ts"
  ],
  "exclude": [
    "jest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "../../packages/demo-shared/src/**/*.test.ts",
    "../../packages/demo-shared/src/**/*.spec.ts",
    "../../packages/toolkit/**/*.spec.ts",
    "../../packages/toolkit/test-setup.ts",
    "../../packages/toolkit/test-setup.browser.ts",
    "../../packages/toolkit/test.utilities.ts"
  ]
}
