{
  "compileOnSave": false,
  "compilerOptions": {
    "declaration": false,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "rootDir": ".",
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "ES2022",
    "useDefineForClassFields": false,
    "paths": {
      "@ngx-signal-forms/toolkit": ["./packages/toolkit/index.ts"],
      "@ngx-signal-forms/toolkit/core": ["./packages/toolkit/core/index.ts"],
      "@ngx-signal-forms/toolkit/assistive": [
        "./packages/toolkit/assistive/index.ts"
      ],
      "@ngx-signal-forms/toolkit/form-field": [
        "./packages/toolkit/form-field/index.ts"
      ],
      "@ngx-signal-forms/toolkit/vest": [
        "./packages/toolkit/vest/src/index.ts"
      ],
      "@ngx-signal-forms/toolkit/headless": [
        "./packages/toolkit/headless/src/index.ts"
      ],
      "@ngx-signal-forms/demo-shared": ["./packages/demo-shared/src/index.ts"],
      "@ngx-signal-forms/a11y-testing": ["./tools/a11y/scan.ts"],
      "@ngx-signal-forms/debugger": ["./libs/debugger/src/index.ts"],
      "@spartan-ng/helm": ["./libs/spartan/ui/src/index.ts"],
      "@spartan-ng/helm/input": ["./libs/spartan/ui/input/src/index.ts"],
      "@spartan-ng/helm/utils": ["./libs/spartan/ui/utils/src/index.ts"],
      "@spartan-ng/helm/label": ["./libs/spartan/ui/label/src/index.ts"],
      "@spartan-ng/helm/select": ["./libs/spartan/ui/select/src/index.ts"],
      "@spartan-ng/helm/icon": ["./libs/spartan/ui/icon/src/index.ts"],
      "@spartan-ng/helm/checkbox": ["./libs/spartan/ui/checkbox/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"],
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true,
    "typeCheckHostBindings": true,
    "extendedDiagnostics": {
      "checks": {
        "controlFlowPreventingContentProjection": "error",
        "interpolatedSignalNotInvoked": "error",
        "invalidBananaInBox": "error",
        "missingControlFlowDirective": "error",
        "missingNgForOfLet": "error",
        "missingStructuralDirective": "error",
        "nullishCoalescingNotNullable": "error",
        "optionalChainNotNullable": "error",
        "skipHydrationNotStatic": "error",
        "suffixNotSupported": "error",
        "textAttributeNotBinding": "error",
        "uninvokedFunctionInEventBinding": "error",
        "uninvokedTrackFunction": "error",
        "unparenthesizedNullishCoalescing": "error",
        "unusedLetDeclaration": "error",
        "unusedStandaloneImports": "error"
      }
    }
  }
}
