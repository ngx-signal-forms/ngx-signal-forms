{
  "name": "ui-helm",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/spartan/ui/src",
  "prefix": "hlm",
  "tags": ["scope:lib", "type:lib"],
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/spartan/ui/ng-package.json",
        "tsConfig": "libs/spartan/ui/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/spartan/ui/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    }
  }
}
