{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "packages"
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/.eslintrc.json",
      "!{projectRoot}/eslint.config.mjs",
      "!{workspaceRoot}/.oxlintrc.json",
      "!{workspaceRoot}/.oxfmtrc.json",
      "!{projectRoot}/vite.config.{js,cjs,mjs,ts,cts,mts}",
      "!{projectRoot}/vitest.config.{js,cjs,mjs,ts,cts,mts}",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/src/test-setup.[jt]s",
      "!{projectRoot}/test-setup.[jt]s",
      "!{projectRoot}/jest.config.[jt]s"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/.github/workflows/ci.yml",
      "{workspaceRoot}/.github/workflows/release.yml",
      "{workspaceRoot}/.github/workflows/publish.yml"
    ]
  },
  "nxCloudId": "6996105d7ca3ad8352dfd299",
  "targetDefaults": {
    "@angular/build:application": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "lint": {
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/.oxlintrc.json"]
    },
    "@nx/vitest:test": {
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "test-browser": {
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "@nx/angular:package": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "e2e": {
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "e2e-ci": {
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "@nx/js:tsc": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    }
  },
  "plugins": [],
  "generators": {
    "@nx/angular:application": {
      "e2eTestRunner": "playwright",
      "linter": "none",
      "style": "css",
      "unitTestRunner": "vitest-analog"
    },
    "@nx/angular:library": {
      "linter": "none",
      "unitTestRunner": "vitest-analog"
    },
    "@nx/angular:component": {
      "style": "css"
    }
  },
  "release": {
    "projects": ["toolkit"],
    "git": {
      "commit": true,
      "commitMessage": "chore(release): publish {version}",
      "tag": true,
      "tagMessage": "Release {version}",
      "push": true
    },
    "changelog": {
      "workspaceChangelog": false,
      "projectChangelogs": {
        "createRelease": "github",
        "file": false,
        "renderOptions": {
          "authors": true,
          "commitReferences": true,
          "versionTitleDate": true
        }
      }
    },
    "conventionalCommits": {
      "types": {
        "feat": {
          "semverBump": "minor",
          "changelog": {
            "title": "🚀 Features"
          }
        },
        "fix": {
          "semverBump": "patch",
          "changelog": {
            "title": "🩹 Bug Fixes"
          }
        },
        "perf": {
          "semverBump": "patch",
          "changelog": {
            "title": "⚡ Performance"
          }
        },
        "refactor": {
          "semverBump": "none",
          "changelog": {
            "title": "♻️ Refactoring"
          }
        },
        "docs": {
          "semverBump": "none",
          "changelog": {
            "title": "📚 Documentation"
          }
        },
        "test": {
          "semverBump": "none",
          "changelog": false
        },
        "build": {
          "semverBump": "none",
          "changelog": false
        },
        "ci": {
          "semverBump": "none",
          "changelog": false
        },
        "chore": {
          "semverBump": "none",
          "changelog": false
        }
      }
    },
    "releaseTagPattern": "v{version}"
  },
  "analytics": false
}
